@using System.Drawing.Drawing2D
@using System.Text.Json.Serialization
@using Dg.ProviderOrder.Mokumentation.ArchitectureBricks
@inject IJSRuntime JS

<canvas id="verticalSlicesCanvas" style="border:1px solid #000000;"></canvas>
@code {


    public async Task RenderAsync(IReadOnlyList<VerticalSlice> verticalSlices, bool reset = false)
    {
        var graphData = GetGraphData(verticalSlices);
        await JS.InvokeVoidAsync("renderVerticalSlices", graphData, reset);
    }

    public sealed class RenderingOptions
    {
        public bool RenderDetailedVerticalSlices { get; set; } = true;
    } 

    public async Task SetRenderingOptionsAsync(RenderingOptions options)
    {
        await JS.InvokeVoidAsync("setRenderingOptions", options);
    }

    private static GraphData GetGraphData(IReadOnlyList<VerticalSlice> verticalSlices)
    {
        var graphData = new GraphData()
        {
            VerticalSlices = new List<GraphVerticalSlice>(),
        };
        foreach (var verticalSlice in verticalSlices)
        {
            var graphVerticalSlice = new GraphVerticalSlice()
            {
                PrimaryPort = VerticalSliceNode.ForPrimaryPort(verticalSlice.PrimaryPort),
            };
            
            graphVerticalSlice.PrimaryAdapterTuples.AddRange(verticalSlice.PrimaryAdapters.Select(PrimaryAdapterTuple.FromPrimaryAdapter));
            graphVerticalSlice.NServiceBusPayloads.AddRange(verticalSlice.NServiceBusPayloads.Select(VerticalSliceNode.ForNServiceBusPayload));
            graphVerticalSlice.KafkaPayloads.AddRange(verticalSlice.KafkaPayloads.Select(VerticalSliceNode.ForKafkaPayload));
            graphVerticalSlice.WebApiServiceClientCalls.AddRange(verticalSlice.WebApiServiceClientCalls.Select(VerticalSliceNode.ForWebApiServiceClientCall));
            graphVerticalSlice.VerticalSliceCalls.AddRange(verticalSlice.VerticalSliceCalls.Select(VerticalSliceCall.FromVerticalSliceCall));
            graphVerticalSlice.Id = verticalSlice.Id;
            graphData.VerticalSlices.Add(graphVerticalSlice);
        }
        return graphData;
    }


    private class GraphData
    {
        public List<GraphVerticalSlice> VerticalSlices { get; set; }
    }

    private class GraphVerticalSlice
    {
        public string Id { get; set; }
        public List<PrimaryAdapterTuple> PrimaryAdapterTuples { get; set;} = new List<PrimaryAdapterTuple>();
        public VerticalSliceNode PrimaryPort { get; set; }
        public List<VerticalSliceNode> NServiceBusPayloads { get; set;} = new List<VerticalSliceNode>();
        public List<VerticalSliceNode> KafkaPayloads { get; set;} = new List<VerticalSliceNode>();
        public List<VerticalSliceNode> WebApiServiceClientCalls { get; set;} = new List<VerticalSliceNode>();
        public List<VerticalSliceCall> VerticalSliceCalls { get; set;} = new List<VerticalSliceCall>();
    }

    private enum VerticalSliceNodeType
    {
        PrimaryAdapter = 0,
        PrimaryAdapterPayload = 1,
        PrimaryPort = 2,
        NServiceBusPayload = 3,
        KafkaPayload = 4,
        OutboxPayload = 5,
        WebApiServiceClientCall = 6,
        VerticalSliceCall = 7
    }

    private class VerticalSliceCall
    {
        public string CalledVerticalSliceId { get; set; }
        public string CalledPrimaryAdapterId { get; set; }
        public string PayloadId { get; set; }
        
        public static VerticalSliceCall FromVerticalSliceCall(Dg.ProviderOrder.Mokumentation.ArchitectureBricks.VerticalSliceCall verticalSliceCall) => new VerticalSliceCall
        {
            CalledVerticalSliceId = verticalSliceCall.CalledVerticalSlice.Id,
            CalledPrimaryAdapterId = verticalSliceCall.CalledPrimaryAdapter.ClassTypeSymbol.FullName.Value,
            PayloadId = verticalSliceCall.Payload.FullName.Value
        };
    }
    

    private class VerticalSliceNode
    {
        public string Id { get; set; }
        public string Text { get; set; }
        public string? Link { get; set; }
        public VerticalSliceNodeType NodeTypeId { get; set; }

        public static VerticalSliceNode ForPrimaryAdapter(PrimaryAdapter primaryAdapter) => new VerticalSliceNode
        {
            Text = primaryAdapter.ClassTypeSymbol.Name,
            Id = primaryAdapter.ClassTypeSymbol.FullName.Value,
            NodeTypeId = VerticalSliceNodeType.PrimaryAdapter
        };
        
        public static VerticalSliceNode ForPrimaryAdapterPayload(NamedTypeSymbol payloadType) => new VerticalSliceNode
        {
            Text = payloadType.Name,
            Id = payloadType.FullName.Value,
            NodeTypeId = VerticalSliceNodeType.PrimaryAdapterPayload
        };
        
        public static VerticalSliceNode ForPrimaryPort(PrimaryPort primaryPort) => new VerticalSliceNode
        {
            Text = primaryPort.ImplementationClass.Name,
            Id = primaryPort.FullName.Value,
            NodeTypeId = VerticalSliceNodeType.PrimaryPort,
            Link = primaryPort.VersionControlInfo?.LinkToRemoteFile
        };
        
        public static VerticalSliceNode ForNServiceBusPayload(NamedTypeSymbol payloadType) => new VerticalSliceNode
        {
            Text = payloadType.Name,
            Id = payloadType.FullName.Value,
            NodeTypeId = VerticalSliceNodeType.NServiceBusPayload
        };
        
        public static VerticalSliceNode ForKafkaPayload(NamedTypeSymbol payloadType) => new VerticalSliceNode
        {
            Text = payloadType.Name,
            Id = payloadType.FullName.Value,
            NodeTypeId = VerticalSliceNodeType.KafkaPayload
        };
        
        public static VerticalSliceNode ForOutboxPayload(NamedTypeSymbol payloadType) => new VerticalSliceNode
        {
            Text = payloadType.Name,
            Id = payloadType.FullName.Value,
            NodeTypeId = VerticalSliceNodeType.OutboxPayload
        };
        
        public static VerticalSliceNode ForWebApiServiceClientCall(SerializableWebApiServiceClientCall webApiServiceClientCall) => new VerticalSliceNode
        {
            Text = webApiServiceClientCall.Method.Name,
            Id = webApiServiceClientCall.Method.FullName.Value,
            NodeTypeId = VerticalSliceNodeType.WebApiServiceClientCall
        };

    }

    private class PrimaryAdapterTuple
    {
        public VerticalSliceNode PrimaryAdapter { get; set; }
        public VerticalSliceNode? Payload { get; set; }

        public static PrimaryAdapterTuple FromPrimaryAdapter(PrimaryAdapter primaryAdapter) => new PrimaryAdapterTuple()
        {
            PrimaryAdapter = VerticalSliceNode.ForPrimaryAdapter(primaryAdapter),
            Payload = primaryAdapter.PayloadType != null
                ? VerticalSliceNode.ForPrimaryAdapterPayload(primaryAdapter.PayloadType)
                : null
        };
    }
}